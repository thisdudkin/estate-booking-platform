<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <artifactId>estate-booking-platform-profile-service</artifactId>
    <name>Profile Service</name>

    <parent>
        <groupId>io.petproject</groupId>
        <artifactId>estate-booking-platform-parent</artifactId>
        <version>0.1.0</version>
    </parent>

    <dependencies>
        <!-- Web -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-webmvc</artifactId>
        </dependency>

        <!-- Security -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-security-oauth2-resource-server</artifactId>
        </dependency>

        <!-- SQL -->
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <scope>runtime</scope>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-flyway</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-jooq</artifactId>
        </dependency>
        <dependency>
            <groupId>org.flywaydb</groupId>
            <artifactId>flyway-database-postgresql</artifactId>
            <scope>compile</scope>
        </dependency>

        <!-- I/O -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-validation</artifactId>
        </dependency>

        <!-- Ops -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-actuator</artifactId>
        </dependency>

        <!-- Testing -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-testcontainers</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers-junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.testcontainers</groupId>
            <artifactId>testcontainers-postgresql</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <!-- Profile Service Plugins -->
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-enforcer-plugin</artifactId>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-failsafe-plugin</artifactId>
            </plugin>
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
            </plugin>
            <plugin>
                <groupId>org.testcontainers</groupId>
                <artifactId>testcontainers-jooq-codegen-maven-plugin</artifactId>
                <executions>
                    <execution>
                        <id>generate-jooq-sources</id>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                        <configuration>
                            <database>
                                <type>${testcontainers.default.database}</type>
                                <containerImage>postgres:18.4-alpine</containerImage>
                                <databaseName>profile_db</databaseName>
                                <username>test</username>
                                <password>test</password>
                            </database>
                            <flyway>
                                <defaultSchema>data</defaultSchema>
                                <createSchemas>true</createSchemas>
                                <table>flyway_schema_history</table>
                                <locations>
                                    filesystem:${project.basedir}/src/main/resources/db/migration
                                </locations>
                            </flyway>
                            <jooq>
                                <generator>
                                    <database>
                                        <name>org.jooq.meta.postgres.PostgresDatabase</name>
                                        <includes>.*</includes>
                                        <excludes>flyway_schema_history</excludes>
                                        <inputSchema>data</inputSchema>
                                    </database>
                                    <generate>
                                        <!-- Core Jooq persistence model -->
                                        <records>true</records>
                                        <tables>true</tables>
                                        <relations>true</relations>
                                        <keys>true</keys>
                                        <indexes>true</indexes>
                                        <sequences>true</sequences>

                                        <!-- Don't generate competing domain models -->
                                        <pojos>false</pojos>
                                        <daos>false</daos>
                                        <interfaces>false</interfaces>

                                        <!-- Prefer explicit mapper layer instead of generated mutable DTOs -->
                                        <immutablePojos>false</immutablePojos>
                                        <serializablePojos>false</serializablePojos>

                                        <!-- Java 8+ date/time API -->
                                        <javaTimeTypes>true</javaTimeTypes>

                                        <!-- Useful for Jooq Records only; optional -->
                                        <fluentSetters>true</fluentSetters>

                                        <!-- Keep generated code leaner -->
                                        <javadoc>false</javadoc>
                                        <comments>false</comments>
                                        <deprecated>false</deprecated>

                                        <!-- Avoid framework annotations leaking into generated persistence code -->
                                        <springAnnotations>false</springAnnotations>
                                        <validationAnnotations>false</validationAnnotations>
                                        <jpaAnnotations>false</jpaAnnotations>
                                    </generate>
                                    <target>
                                        <packageName>io.petproject.estate.booking.platform.profile.infrastructure.jooq</packageName>
                                        <directory>target/generated-sources/jooq</directory>
                                    </target>
                                </generator>
                            </jooq>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

</project>
